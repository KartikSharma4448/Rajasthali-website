# Rajasthali Tours - Environment Variables
# Copy this file to .env for local development.
# Set these as environment variables in Render or Vercel.

# Current production URL (no trailing slash).
# Used for canonical URLs, robots.txt, sitemap, and Open Graph image URLs.
SITE_URL=https://rajasthali-website.onrender.com

# When the final custom domain is live, change SITE_URL to:
# SITE_URL=https://rajasthalitours.com

# Sitemap lastmod date. Update when you publish major content changes (YYYY-MM-DD).
SITE_LASTMOD=2025-06-21

# Node environment.
NODE_ENV=production

# Local development port. Render/Vercel assign their own port.
PORT=5000
