# ─────────────────────────────────────────────────────────────
# Rajasthali Tours — Environment Variables
# Copy this file to .env for local development
# Set these as Environment Variables in Vercel dashboard
# ─────────────────────────────────────────────────────────────

# Your production domain (no trailing slash)
# Used to generate canonical URLs, sitemap, and OG image URLs
SITE_URL=https://rajasthalitours.com

# Sitemap lastmod date — update this when you publish major content changes (YYYY-MM-DD)
SITE_LASTMOD=2025-06-21

# Node environment
NODE_ENV=production

# Port (Vercel ignores this — it assigns its own port)
PORT=5000
