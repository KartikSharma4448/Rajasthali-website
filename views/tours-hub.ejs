<!DOCTYPE html>
<html lang="en">
<%- include('partials/seo-head', { seo }) %>
<% if (false) { %>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tour Destinations from Jaipur — Rajasthan & All India | Rajasthali Tours</title>
  <meta name="description" content="Book taxi or tour to 30+ destinations from Jaipur — Udaipur, Jodhpur, Jaisalmer, Agra (Taj Mahal), Delhi, Haridwar, Shimla, Manali, Amritsar, Varanasi & more. Govt-approved. ₹1,600 onwards.">
  <meta name="keywords" content="tour destinations from Jaipur, Jaipur taxi all destinations, Rajasthan tour, India tour from Jaipur, Jaipur to Udaipur, Jaipur to Agra, Jaipur to Delhi, Jaipur to Shimla, Jaipur to Haridwar, Jaipur to Amritsar, Rajasthali Tours">
  <link rel="canonical" href="https://rajasthalitours.com/tours">
  <meta property="og:title" content="Tour Destinations from Jaipur — Rajasthan & All India | Rajasthali Tours">
  <meta property="og:description" content="30+ tour destinations from Jaipur across Rajasthan and India. Luxury taxi, cab, and tour packages. 500+ vehicles, govt-approved.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://rajasthalitours.com/tours">
  <meta property="og:image" content="https://rajasthalitours.com/rajasthalitours_images/hero_rajasthan.png">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" type="image/png" href="/rajasthalitours_images/logo.png">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/seo-pages.css">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://rajasthalitours.com/" },
      { "@type": "ListItem", "position": 2, "name": "Tour Destinations", "item": "https://rajasthalitours.com/tours" }
    ]
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Tour Destinations from Jaipur — Rajasthan & All India",
    "description": "30+ travel destinations covered by Rajasthali Tours & Travels from Jaipur, Rajasthan",
    "itemListElement": [
      <% destinations.forEach(function(d, i) { %>
      {
        "@type": "ListItem",
        "position": <%= i + 1 %>,
        "name": "<%= d.name %>",
        "url": "https://rajasthalitours.com/tours/<%= d.slug %>"
      }<%= i < destinations.length - 1 ? ',' : '' %>
      <% }); %>
    ]
  }
  </script>
</head>
<% } %>
<body class="seo-body">

  <%- include('partials/seo-header') %>

  <section class="seo-hero">
    <div class="seo-hero-inner">
      <nav class="seo-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <span>Tour Destinations</span>
      </nav>

      <div class="seo-badge">GOVERNMENT APPROVED TOUR OPERATOR</div>
      <h1 class="seo-hero-title">
        Tour Destinations <span class="seo-highlight">from Jaipur</span>
      </h1>
      <p class="seo-hero-sub">
        Luxury transport to <strong><%= destinations.length %>+ destinations</strong> across Rajasthan and India — with professional chauffeurs, 500+ premium vehicles, and 15+ years of road expertise.
      </p>

      <div class="seo-hero-stats">
        <div class="seo-stat"><span class="seo-stat-num"><%= destinations.length %>+</span><span class="seo-stat-label">Destinations</span></div>
        <div class="seo-stat"><span class="seo-stat-num">500+</span><span class="seo-stat-label">Vehicles</span></div>
        <div class="seo-stat"><span class="seo-stat-num">15+</span><span class="seo-stat-label">Years Service</span></div>
        <div class="seo-stat"><span class="seo-stat-num">10K+</span><span class="seo-stat-label">Happy Customers</span></div>
      </div>

      <div class="seo-hero-ctas">
        <a href="tel:+919785307799" class="seo-cta-primary">📞 Book a Taxi</a>
        <a href="/tour-packages" class="seo-cta-secondary">🗺️ View Tour Packages</a>
      </div>
    </div>
  </section>

  <%
    const rajasthanDests = destinations.filter(d => d.region === 'Rajasthan');
    const panIndiaDests = destinations.filter(d => d.region !== 'Rajasthan');
  %>

  <section class="seo-section" style="background: #0f0f1a;">
    <div class="seo-container">
      <h2 class="seo-section-title">🏜️ Rajasthan Destinations</h2>
      <p class="seo-section-sub">Covering all major cities and hidden gems of the Land of Kings — from the Pink City to the Golden Desert.</p>

      <div class="dest-grid">
        <% rajasthanDests.forEach(function(d) { %>
        <article class="dest-card">
          <div class="dest-card-header">
            <h3><%= d.name %></h3>
            <p class="dest-nickname"><%= d.nickname %></p>
          </div>
          <div class="dest-card-body">
            <div class="dest-meta">
              <span>📍 <%= d.distance %> km</span>
              <span>⏱️ <%= d.driveTime %></span>
            </div>
            <p class="dest-desc"><%= d.description.substring(0, 120) %>...</p>
            <div class="dest-highlights">
              <% d.topAttractions.slice(0, 2).forEach(function(a) { %>
              <span class="dest-tag-sm">✓ <%= a.name %></span>
              <% }); %>
            </div>
          </div>
          <div class="dest-card-footer">
            <a href="/tours/<%= d.slug %>" class="dest-link-btn">View Details & Book →</a>
          </div>
        </article>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="seo-section" style="background: #080810;">
    <div class="seo-container">
      <h2 class="seo-section-title">🇮🇳 Pan-India Destinations</h2>
      <p class="seo-section-sub">From the spiritual ghats of Varanasi to the snow peaks of Manali — Rajasthali Tours covers all of India from Jaipur.</p>

      <div class="dest-grid">
        <% panIndiaDests.forEach(function(d) { %>
        <article class="dest-card">
          <div class="dest-card-header">
            <h3><%= d.name %></h3>
            <p class="dest-nickname"><%= d.nickname %> &nbsp;·&nbsp; <span class="dest-region"><%= d.region %></span></p>
          </div>
          <div class="dest-card-body">
            <div class="dest-meta">
              <span>📍 <%= d.distance %> km</span>
              <span>⏱️ <%= d.driveTime %></span>
            </div>
            <p class="dest-desc"><%= d.description.substring(0, 120) %>...</p>
            <div class="dest-highlights">
              <% d.topAttractions.slice(0, 2).forEach(function(a) { %>
              <span class="dest-tag-sm">✓ <%= a.name %></span>
              <% }); %>
            </div>
          </div>
          <div class="dest-card-footer">
            <a href="/tours/<%= d.slug %>" class="dest-link-btn">View Details & Book →</a>
          </div>
        </article>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="seo-section" style="background: #0f0f1a;">
    <div class="seo-container">
      <h2 class="seo-section-title">Popular Tour Packages</h2>
      <p class="seo-section-sub">Looking for a complete holiday? Browse our curated multi-day tour circuits.</p>
      <div class="pkg-cta-grid">
        <a href="/tour-packages/golden-triangle-tour" class="pkg-cta-card">
          <strong>Golden Triangle</strong>
          <span>Delhi – Agra – Jaipur · 4 Days</span>
        </a>
        <a href="/tour-packages/royal-rajasthan-circuit" class="pkg-cta-card">
          <strong>Royal Rajasthan Circuit</strong>
          <span>Jaipur – Jodhpur – Jaisalmer – Udaipur · 8 Days</span>
        </a>
        <a href="/tour-packages/char-dham-yatra" class="pkg-cta-card">
          <strong>Char Dham Yatra</strong>
          <span>Kedarnath – Badrinath – Gangotri – Yamunotri · 12 Days</span>
        </a>
        <a href="/tour-packages/rajasthan-desert-safari" class="pkg-cta-card">
          <strong>Rajasthan Desert Safari</strong>
          <span>Bikaner – Jaisalmer – Jodhpur · 6 Days</span>
        </a>
        <a href="/tour-packages/golden-triangle-with-rajasthan" class="pkg-cta-card">
          <strong>Golden Triangle + Rajasthan</strong>
          <span>Delhi – Agra – Jaipur – Udaipur · 10 Days</span>
        </a>
        <a href="/tour-packages" class="pkg-cta-card" style="border-color: var(--brand-pink);">
          <strong>All Tour Packages →</strong>
          <span><%= tourPackages.length %> curated circuits available</span>
        </a>
      </div>
    </div>
  </section>

  <section class="seo-section" style="background: #080810;">
    <div class="seo-container">
      <h2 class="seo-section-title">Quick Route Fares</h2>
      <p class="seo-section-sub">Transparent, all-inclusive fares from Jaipur. No hidden charges. All tolls, fuel, and driver included.</p>
      <div class="fare-table-wrap">
        <table class="fare-table">
          <thead>
            <tr>
              <th>Destination</th>
              <th>Distance</th>
              <th>Drive Time</th>
              <th>Sedan (₹)</th>
              <th>Innova Crysta (₹)</th>
              <th>Fortuner (₹)</th>
            </tr>
          </thead>
          <tbody>
            <% destinations.slice(0, 16).forEach(function(d) {
              const sedan = Math.round(d.distance * 11 / 100) * 100;
              const innova = Math.round(d.distance * 16 / 100) * 100;
              const fortuner = Math.round(d.distance * 22 / 100) * 100;
            %>
            <tr>
              <td><a href="/tours/<%= d.slug %>"><%= d.name %></a></td>
              <td><%= d.distance %> km</td>
              <td><%= d.driveTime %></td>
              <td>₹<%= sedan.toLocaleString() %></td>
              <td>₹<%= innova.toLocaleString() %></td>
              <td>₹<%= fortuner.toLocaleString() %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <p style="text-align: center; margin-top: 1rem; color: #aaa; font-size: 0.85rem;">* Indicative fares. Exact prices vary by season and availability. <a href="tel:+919785307799" style="color: var(--brand-pink);">Call for exact quote →</a></p>
    </div>
  </section>

  <section class="seo-cta-section">
    <div class="seo-container">
      <h2>Ready to Travel? Book Your Jaipur Taxi Now</h2>
      <p>Call or WhatsApp — we'll confirm your cab in under 30 minutes with a fixed, all-inclusive price.</p>
      <div class="seo-hero-ctas">
        <a href="tel:+919785307799" class="seo-cta-primary">📞 +91 97853 07799</a>
        <a href="https://wa.me/919785307799?text=Hi%20Rajasthali%20Tours%2C%20I%20want%20to%20book%20a%20taxi." target="_blank" rel="noopener noreferrer" class="seo-cta-secondary">💬 WhatsApp</a>
      </div>
    </div>
  </section>

  <%- include('partials/seo-footer') %>
</body>
</html>
