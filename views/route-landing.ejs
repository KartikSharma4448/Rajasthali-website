<!DOCTYPE html>
<html lang="en">
<%- include('partials/seo-head', { seo }) %>
<body class="seo-body">
  <%- include('partials/seo-header') %>

  <section class="seo-hero">
    <div class="seo-hero-inner">
      <nav class="seo-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a><span>›</span>
        <a href="/taxi-from-jaipur">Taxi from Jaipur</a><span>›</span>
        <span>Jaipur to <%= dest.name %> Taxi</span>
      </nav>
      <div class="seo-hero-badge">Govt. Approved · IATA Certified · Since 2010</div>
      <h1>Jaipur to <%= dest.name %> Taxi<br>
        <span style="color:var(--brand-pink);">— <%= dest.nickname %></span>
      </h1>
      <p class="seo-hero-sub">
        <strong><%= dest.distance %> km</strong> &nbsp;·&nbsp;
        Drive time: <strong><%= dest.driveTime %></strong> &nbsp;·&nbsp;
        Starting from <strong>₹<%= dest.slug==='agra'?'3,200':dest.slug==='udaipur'?'4,800':dest.slug==='delhi'?'3,500':dest.slug==='jodhpur'?'4,200':'6,500' %></strong>
      </p>
      <div class="seo-hero-stats">
        <div><strong><%= dest.distance %> km</strong><span>Distance</span></div>
        <div><strong><%= dest.driveTime %></strong><span>Drive Time</span></div>
        <div><strong>500+</strong><span>Vehicles</span></div>
        <div><strong>24/7</strong><span>Available</span></div>
      </div>
      <div class="seo-hero-ctas">
        <a href="tel:+919785307799" class="btn-seo-primary">📞 Book Taxi Now</a>
        <a href="https://wa.me/919785307799?text=Hello!%20I%20want%20to%20book%20a%20Jaipur%20to%20<%= encodeURIComponent(dest.name) %>%20taxi."
           class="btn-seo-outline" target="_blank" rel="noopener noreferrer">💬 WhatsApp Quote</a>
      </div>
    </div>
  </section>

  <main class="seo-main">
    <div class="seo-container">

      <section class="dest-about">
        <h2>Jaipur to <%= dest.name %> Taxi Service</h2>
        <p class="dest-intro-text"><%= dest.description %></p>
      </section>

      <!-- Fare Table -->
      <section class="svc-fleet">
        <h2>Taxi Fare: Jaipur to <%= dest.name %></h2>
        <div class="fleet-table-wrap">
          <table class="fleet-table">
            <thead><tr><th>Vehicle</th><th>Capacity</th><th>One-Way Fare</th><th>Round Trip</th></tr></thead>
            <tbody>
              <% const fares = {
                agra:     [{v:'Sedan (Swift Dzire)',c:'4 Pax',ow:'₹3,200',rt:'₹5,500'},{v:'Toyota Innova Crysta',c:'7 Pax',ow:'₹4,800',rt:'₹7,500'},{v:'Toyota Fortuner',c:'7 Pax',ow:'₹7,000',rt:'₹11,000'}],
                udaipur:  [{v:'Sedan (Swift Dzire)',c:'4 Pax',ow:'₹4,800',rt:'₹8,500'},{v:'Toyota Innova Crysta',c:'7 Pax',ow:'₹6,500',rt:'₹11,000'},{v:'Toyota Fortuner',c:'7 Pax',ow:'₹9,500',rt:'₹16,000'}],
                delhi:    [{v:'Sedan (Swift Dzire)',c:'4 Pax',ow:'₹3,500',rt:'₹6,000'},{v:'Toyota Innova Crysta',c:'7 Pax',ow:'₹5,000',rt:'₹8,500'},{v:'Toyota Fortuner',c:'7 Pax',ow:'₹7,500',rt:'₹12,500'}],
                jodhpur:  [{v:'Sedan (Swift Dzire)',c:'4 Pax',ow:'₹4,200',rt:'₹7,500'},{v:'Toyota Innova Crysta',c:'7 Pax',ow:'₹6,000',rt:'₹10,000'},{v:'Toyota Fortuner',c:'7 Pax',ow:'₹8,500',rt:'₹14,000'}],
                jaisalmer:[{v:'Sedan (Swift Dzire)',c:'4 Pax',ow:'₹6,500',rt:'₹11,500'},{v:'Toyota Innova Crysta',c:'7 Pax',ow:'₹9,000',rt:'₹15,500'},{v:'Toyota Fortuner',c:'7 Pax',ow:'₹12,000',rt:'₹20,000'}]
              }; %>
              <% (fares[dest.slug] || fares.agra).forEach(function(row){ %>
              <tr>
                <td><strong><%= row.v %></strong></td>
                <td><%= row.c %></td>
                <td style="color:var(--brand-gold);font-weight:700"><%= row.ow %></td>
                <td><%= row.rt %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <p style="color:#aaa;font-size:0.85rem;margin-top:0.75rem;">
          * Fares include toll, driver allowance &amp; GST. Call <a href="tel:+919785307799" style="color:var(--brand-pink)">+91 97853 07799</a> for exact quotes.
        </p>
      </section>

      <!-- Route Highlights -->
      <section class="dest-about">
        <h2>Route Highlights: Jaipur → <%= dest.name %></h2>
        <div class="dest-route-box">
          <ul class="route-list">
            <% dest.routeHighlights.forEach(function(r){ %><li><%= r %></li><% }); %>
          </ul>
        </div>
      </section>

      <!-- Top Attractions -->
      <section class="dest-attractions">
        <h2>Top Attractions in <%= dest.name %></h2>
        <div class="attractions-grid">
          <% dest.topAttractions.slice(0,4).forEach(function(a){ %>
          <div class="attraction-card">
            <h3><%= a.name %></h3>
            <p><%= a.detail %></p>
          </div>
          <% }); %>
        </div>
      </section>

      <!-- Booking CTA -->
      <section class="dest-booking-cta">
        <div class="booking-cta-inner">
          <h2>Book Jaipur → <%= dest.name %> Taxi</h2>
          <p>Professional chauffeur · Toll included · 24/7 support · GST invoice</p>
          <div class="booking-cta-btns">
            <a href="tel:+919785307799" class="btn-seo-primary">📞 +91 97853 07799</a>
            <a href="mailto:reservation@rajasthalitours.com?subject=Taxi%20Booking:%20Jaipur%20to%20<%= encodeURIComponent(dest.name) %>"
               class="btn-seo-outline">✉ Email Reservation</a>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="dest-faq">
        <h2>FAQs: Jaipur to <%= dest.name %> Taxi</h2>
        <div class="faq-list">
          <% dest.faqs.forEach(function(faq, i){ %>
          <details class="faq-item" <%= i===0?'open':'' %>>
            <summary class="faq-question"><%= faq.q %></summary>
            <div class="faq-answer"><p><%= faq.a %></p></div>
          </details>
          <% }); %>
        </div>
      </section>

      <!-- Cross-links to full tour page + related routes -->
      <section class="dest-related">
        <h2>Explore More</h2>
        <div class="related-grid">
          <a href="/tours/<%= dest.slug %>" class="related-card">
            <strong><%= dest.name %> Full Tour Guide →</strong>
            <span>Attractions, best time, popular tours</span>
          </a>
          <a href="/taxi-from-jaipur" class="related-card">
            <strong>All Destinations →</strong>
            <span>30+ routes from Jaipur</span>
          </a>
          <a href="/tour-packages" class="related-card">
            <strong>Tour Packages →</strong>
            <span>Curated multi-day itineraries</span>
          </a>
          <a href="/fleet" class="related-card">
            <strong>Our Fleet →</strong>
            <span>Choose your vehicle</span>
          </a>
        </div>
      </section>

    </div>
  </main>

  <%- include('partials/seo-footer') %>
</body>
</html>
