<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= dest.metaTitle %></title>
  <meta name="description" content="<%= dest.metaDescription %>">
  <meta name="keywords" content="<%= dest.heroKeyword %>, Jaipur to <%= dest.name %> cab, <%= dest.name %> tour package, <%= dest.name %> travel, Rajasthali Tours">
  <link rel="canonical" href="https://rajasthalitours.com/tours/<%= dest.slug %>">
  <meta property="og:title" content="<%= dest.metaTitle %>">
  <meta property="og:description" content="<%= dest.metaDescription %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://rajasthalitours.com/tours/<%= dest.slug %>">
  <meta property="og:image" content="https://rajasthalitours.com/rajasthalitours_images/hero_rajasthan.png">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" type="image/png" href="/rajasthalitours_images/logo.png">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/seo-pages.css">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://rajasthalitours.com/" },
      { "@type": "ListItem", "position": 2, "name": "Tour Destinations", "item": "https://rajasthalitours.com/tours" },
      { "@type": "ListItem", "position": 3, "name": "<%= dest.name %>", "item": "https://rajasthalitours.com/tours/<%= dest.slug %>" }
    ]
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "TouristDestination",
    "name": "<%= dest.name %>, Rajasthan",
    "description": "<%= dest.metaDescription %>",
    "url": "https://rajasthalitours.com/tours/<%= dest.slug %>",
    "touristType": "Cultural tourists, Heritage travellers, Pilgrims, Corporate travellers",
    "includesAttraction": [
      <% dest.topAttractions.slice(0, 3).forEach(function(a, i) { %>
      {
        "@type": "TouristAttraction",
        "name": "<%= a.name %>",
        "description": "<%= a.detail %>"
      }<%= i < 2 ? ',' : '' %>
      <% }); %>
    ]
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      <% dest.faqs.forEach(function(faq, i) { %>
      {
        "@type": "Question",
        "name": "<%= faq.q.replace(/"/g, '\\"') %>",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "<%= faq.a.replace(/"/g, '\\"') %>"
        }
      }<%= i < dest.faqs.length - 1 ? ',' : '' %>
      <% }); %>
    ]
  }
  </script>
</head>
<body class="seo-body">

  <%- include('partials/seo-header') %>

  <section class="seo-hero">
    <div class="seo-hero-inner">
      <nav class="seo-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/tours">Tour Destinations</a>
        <span>›</span>
        <span><%= dest.name %></span>
      </nav>
      <div class="seo-hero-badge">Government Approved Route Operator</div>
      <h1><%= dest.heroKeyword %><br><span style="color: var(--brand-pink);">with Rajasthali Tours</span></h1>
      <p class="seo-hero-sub"><%= dest.nickname %> — <strong><%= dest.distance %> km</strong> from Jaipur via direct highway. Approx <strong><%= dest.driveTime %></strong> with professional chauffeur.</p>
      <div class="seo-hero-stats">
        <div><strong><%= dest.distance %> km</strong><span>Distance</span></div>
        <div><strong><%= dest.driveTime %></strong><span>Drive Time</span></div>
        <div><strong><%= dest.topAttractions.length %>+</strong><span>Key Sights</span></div>
        <div><strong>15+</strong><span>Yrs Operated</span></div>
      </div>
      <div class="seo-hero-ctas">
        <a href="tel:+919785307799" class="btn-seo-primary">Book This Route</a>
        <a href="https://wa.me/919785307799?text=Hello!%20I%20want%20to%20book%20a%20Jaipur%20to%20<%= dest.name %>%20trip." class="btn-seo-outline" target="_blank">WhatsApp Quote</a>
      </div>
    </div>
  </section>

  <main class="seo-main">
    <div class="seo-container">

      <section class="dest-about">
        <h2>About the Route: Jaipur to <%= dest.name %></h2>
        <p class="dest-intro-text"><%= dest.description %></p>

        <div class="dest-route-box">
          <h3>What You'll See on the Way</h3>
          <ul class="route-list">
            <% dest.routeHighlights.forEach(function(r) { %>
            <li><%= r %></li>
            <% }); %>
          </ul>
        </div>
      </section>

      <section class="dest-attractions">
        <h2>Top Attractions in <%= dest.name %></h2>
        <div class="attractions-grid">
          <% dest.topAttractions.forEach(function(attr) { %>
          <div class="attraction-card">
            <h3><%= attr.name %></h3>
            <p><%= attr.detail %></p>
          </div>
          <% }); %>
        </div>
      </section>

      <section class="dest-practical">
        <h2>Planning Your <%= dest.name %> Trip</h2>
        <div class="practical-grid">
          <div class="practical-card">
            <div class="practical-icon">📅</div>
            <h3>Best Time to Visit</h3>
            <p><strong><%= dest.bestTimeToVisit %></strong></p>
            <p style="color: #999; font-size: 0.85rem; margin-top: 8px;">Avoid: <%= dest.avoidMonths %></p>
          </div>
          <div class="practical-card">
            <div class="practical-icon">🚗</div>
            <h3>Recommended Vehicle</h3>
            <p><strong><%= dest.recommendedVehicle %></strong></p>
            <p style="color: #999; font-size: 0.85rem; margin-top: 8px;"><%= dest.vehicleReason %></p>
          </div>
          <div class="practical-card">
            <div class="practical-icon">🗺️</div>
            <h3>Popular Tours</h3>
            <ul style="margin: 0; padding: 0 0 0 1.2rem; color: #ccc; font-size: 0.9rem; line-height: 1.9;">
              <% dest.popularTours.forEach(function(t) { %>
              <li><%= t %></li>
              <% }); %>
            </ul>
          </div>
          <div class="practical-card">
            <div class="practical-icon">📍</div>
            <h3>Nearby From <%= dest.name %></h3>
            <ul style="margin: 0; padding: 0 0 0 1.2rem; color: #ccc; font-size: 0.9rem; line-height: 1.9;">
              <% dest.nearbyFrom.forEach(function(n) { %>
              <li><%= n %></li>
              <% }); %>
            </ul>
          </div>
        </div>
      </section>

      <section class="dest-booking-cta">
        <div class="booking-cta-inner">
          <h2>Book Your Jaipur → <%= dest.name %> Transfer</h2>
          <p>Professional chauffeur · Toll included · 24/7 support · GST invoice</p>
          <div class="booking-cta-btns">
            <a href="tel:+919785307799" class="btn-seo-primary">📞 Call +91 97853 07799</a>
            <a href="mailto:reservation@rajasthalitours.com?subject=Booking%20Enquiry:%20Jaipur%20to%20<%= dest.name %>" class="btn-seo-outline">✉ Email Reservation</a>
          </div>
        </div>
      </section>

      <section class="dest-faq">
        <h2>Frequently Asked Questions: Jaipur to <%= dest.name %></h2>
        <div class="faq-list">
          <% dest.faqs.forEach(function(faq, i) { %>
          <details class="faq-item" <%= i === 0 ? 'open' : '' %>>
            <summary class="faq-question"><%= faq.q %></summary>
            <div class="faq-answer"><p><%= faq.a %></p></div>
          </details>
          <% }); %>
        </div>
      </section>

      <section class="dest-related">
        <h2>Other Popular Destinations</h2>
        <div class="related-grid">
          <% relatedDests.forEach(function(r) { %>
          <a href="/tours/<%= r.slug %>" class="related-card">
            <div class="related-distance"><%= r.distance %> km · <%= r.driveTime %></div>
            <strong><%= r.name %></strong>
            <span><%= r.nickname %></span>
          </a>
          <% }); %>
          <a href="/tours" class="related-card related-all">
            <strong>View All Destinations →</strong>
          </a>
        </div>
      </section>

    </div>
  </main>

  <%- include('partials/seo-footer') %>

</body>
</html>
